# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://invisible-users.com

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=tom@allabout.network
EMAIL_TO=tom@allabout.network

# ConvertKit Configuration (Email Marketing)
CONVERTKIT_API_KEY=your_convertkit_api_key
CONVERTKIT_API_SECRET=your_convertkit_secret
CONVERTKIT_FORM_ID=your_form_id

# Mailchimp Configuration (Alternative)
MAILCHIMP_API_KEY=your_mailchimp_api_key
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your_list_id

# Stripe Configuration (Payment Processing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Product IDs (Create these in Stripe Dashboard)
STRIPE_PRODUCT_DIGITAL=price_digital_edition
STRIPE_PRODUCT_COMPLETE=price_complete_package
STRIPE_PRODUCT_TEAM=price_team_license

# Database (Optional - for storing leads/orders)
# DATABASE_URL=postgresql://user:password@localhost:5432/invisible_users

# Security
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
API_KEY=your_internal_api_key_for_admin_routes

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Storage (for PDFs, if not using external hosting)
CHAPTER_PDF_PATH=./assets/chapter-1.pdf
CHECKLIST_PDF_PATH=./assets/implementation-checklist.pdf

# Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
PLAUSIBLE_DOMAIN=invisible-users.com

# SendGrid (Alternative Email Provider)
SENDGRID_API_KEY=your_sendgrid_api_key

# Postmark (Alternative Email Provider)
POSTMARK_SERVER_TOKEN=your_postmark_token
